---
import BaseLayout from '../layouts/BaseLayout.astro';

const GIST_RAW_URL = "https://gist.githubusercontent.com/bneb/66d185688c92067a1878666b311aab1a/raw/perqed_live_state.json";
---

<BaseLayout title="Minutiae — Perqed Live Feed" activeNav="minutiae">

  <section class="minutiae-header">
    <div class="container container--wide">
      <div class="header-row">
        <div>
          <p class="eyebrow">Live Feed</p>
          <h1 class="header-title">Minutiae</h1>
          <p class="header-desc">
            Live telemetry from the proof engine.
          </p>
        </div>
        <div class="status-badge" id="status-badge">
          <span class="status-dot"></span>
          <span class="status-text">Connecting…</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Status Bar -->
  <section class="sb-section">
    <div class="container container--wide">
      <div class="sb">
        <div class="sb-item">
          <span class="sb-label">Run</span>
          <span class="sb-value" id="sb-run">—</span>
        </div>
        <div class="sb-item">
          <span class="sb-label">Theorem</span>
          <span class="sb-value" id="sb-theorem">—</span>
        </div>
        <div class="sb-item">
          <span class="sb-label">Iteration</span>
          <span class="sb-value" id="sb-iteration">—</span>
        </div>
        <div class="sb-item">
          <span class="sb-label">Status</span>
          <span class="sb-value" id="sb-status">—</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Routing Cascade -->
  <section class="cascade-section">
    <div class="container container--wide">
      <h3 class="panel-heading">Routing Cascade</h3>
      <div class="cascade-grid" id="cascade-grid">
        <div class="cascade-card" id="tier-tactician" data-tier="TACTICIAN">
          <div class="cascade-icon">♟️</div>
          <div class="cascade-name">TACTICIAN</div>
          <div class="cascade-model">prover-v2 (local)</div>
          <div class="cascade-cost">$0</div>
          <div class="cascade-badge" id="badge-tactician">—</div>
        </div>
        <div class="cascade-arrow">→</div>
        <div class="cascade-card" id="tier-reasoner-free" data-tier="REASONER_FREE">
          <div class="cascade-icon">🧠</div>
          <div class="cascade-name">REASONER</div>
          <div class="cascade-model">gemini-2.5-flash</div>
          <div class="cascade-cost">FREE</div>
          <div class="cascade-badge" id="badge-reasoner-free">—</div>
        </div>
        <div class="cascade-arrow">→</div>
        <div class="cascade-card" id="tier-reasoner-paid" data-tier="REASONER_PAID">
          <div class="cascade-icon">🧠</div>
          <div class="cascade-name">REASONER+</div>
          <div class="cascade-model">gemini-3.1-flash-lite</div>
          <div class="cascade-cost">M≥4</div>
          <div class="cascade-badge" id="badge-reasoner-paid">—</div>
        </div>
        <div class="cascade-arrow">→</div>
        <div class="cascade-card" id="tier-architect-pro" data-tier="ARCHITECT_PRO">
          <div class="cascade-icon">🏛️</div>
          <div class="cascade-name">ARCHITECT</div>
          <div class="cascade-model">gemini-3.1-pro</div>
          <div class="cascade-cost">N≥6</div>
          <div class="cascade-badge" id="badge-architect-pro">—</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Signals + History -->
  <section class="panels-section">
    <div class="container container--wide">
      <div class="panels-grid">
        <!-- Signals Panel -->
        <div>
          <h3 class="panel-heading">Routing Signals</h3>
          <div class="signals-panel" id="signals-panel">
            <div class="signal-row">
              <span class="signal-label">consecutiveFailures</span>
              <span class="signal-value" id="sig-failures">0</span>
            </div>
            <div class="signal-threshold">
              <div class="threshold-bar" id="threshold-bar">
                <div class="threshold-fill" id="threshold-fill"></div>
                <div class="threshold-mark" style="left: 57.14%">
                  <span class="threshold-label">M=4</span>
                </div>
                <div class="threshold-mark" style="left: 85.71%">
                  <span class="threshold-label">N=6</span>
                </div>
              </div>
            </div>
            <div class="signal-row">
              <span class="signal-label">goalCount</span>
              <span class="signal-value" id="sig-goals">0</span>
            </div>
            <div class="signal-row">
              <span class="signal-label">isStuckInLoop</span>
              <span class="signal-value" id="sig-loop">false</span>
            </div>
            <div class="signal-row">
              <span class="signal-label">hasArchitectDirective</span>
              <span class="signal-value" id="sig-directive">false</span>
            </div>
            <div class="signal-row">
              <span class="signal-label">totalAttempts</span>
              <span class="signal-value" id="sig-attempts">0</span>
            </div>
          </div>
        </div>

        <!-- Attempt History -->
        <div>
          <h3 class="panel-heading">Attempt History</h3>
          <div class="history-list" id="history-list">
            <p class="empty-msg">Waiting for data…</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Error Terminal -->
  <section class="term-section">
    <div class="container container--wide">
      <div class="terminal">
        <div class="terminal-header">
          <span class="terminal-dot terminal-dot--red"></span>
          <span class="terminal-dot terminal-dot--amber"></span>
          <span class="terminal-dot terminal-dot--green"></span>
          <span class="terminal-title">latest error output</span>
        </div>
        <div class="terminal-body" id="error-output">
          <span class="cursor-blink">▊</span>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline define:vars={{ GIST_RAW_URL }}>
  var POLL_INTERVAL = 3000;
  var lastIteration = -1;

  var AGENT_ICONS = {
    TACTICIAN: "♟️",
    REASONER: "🧠",
    ARCHITECT: "🏛️"
  };

  function render(d) {
    // — Status badge —
    var badge = document.getElementById("status-badge");
    var isLive = d.status === "IN_PROGRESS";
    badge.querySelector(".status-text").textContent = isLive ? "Live" : d.status;
    badge.className = "status-badge" + (isLive ? " live" : "");

    // — Status bar —
    document.getElementById("sb-run").textContent = (d.runId || "—").slice(0, 8);
    document.getElementById("sb-theorem").textContent = d.theorem || "—";
    document.getElementById("sb-iteration").textContent = d.iteration ?? "—";

    var st = document.getElementById("sb-status");
    st.textContent = d.status || "—";
    st.className = "sb-value";
    if (d.status === "SOLVED") st.classList.add("solved");
    else if (d.status === "IN_PROGRESS") st.classList.add("running");
    else if (d.status === "EXHAUSTED") st.classList.add("exhausted");

    // — Routing Cascade —
    var cards = document.querySelectorAll(".cascade-card");
    cards.forEach(function(c) { c.classList.remove("active", "pulse"); });

    if (d.latestLog && d.currentSignals) {
      var failures = d.currentSignals.consecutiveFailures || 0;
      var agent = d.latestLog.agent;
      var activeId = null;

      if (agent === "TACTICIAN") {
        activeId = "tier-tactician";
      } else if (agent === "REASONER" && failures >= 4) {
        activeId = "tier-reasoner-paid";
      } else if (agent === "REASONER") {
        activeId = "tier-reasoner-free";
      } else if (agent === "ARCHITECT") {
        activeId = failures >= 6 ? "tier-architect-pro" : "tier-reasoner-free";
      }

      if (activeId) {
        var el = document.getElementById(activeId);
        if (el) {
          el.classList.add("active");
          if (isLive) el.classList.add("pulse");
        }
      }
    }

    // Count calls per tier from history
    var counts = { tactician: 0, reasonerFree: 0, reasonerPaid: 0, architectPro: 0 };
    if (d.history) {
      var runningFailures = 0;
      d.history.forEach(function(h) {
        if (h.agent === "TACTICIAN") counts.tactician++;
        else if (h.agent === "REASONER" && runningFailures >= 4) counts.reasonerPaid++;
        else if (h.agent === "REASONER") counts.reasonerFree++;
        else if (h.agent === "ARCHITECT") counts.architectPro++;
        if (!h.success) runningFailures++;
        else runningFailures = 0;
      });
    }
    document.getElementById("badge-tactician").textContent = counts.tactician || "—";
    document.getElementById("badge-reasoner-free").textContent = counts.reasonerFree || "—";
    document.getElementById("badge-reasoner-paid").textContent = counts.reasonerPaid || "—";
    document.getElementById("badge-architect-pro").textContent = counts.architectPro || "—";

    // — Signals —
    if (d.currentSignals) {
      var s = d.currentSignals;
      document.getElementById("sig-failures").textContent = s.consecutiveFailures ?? 0;
      document.getElementById("sig-goals").textContent = s.goalCount ?? 0;
      document.getElementById("sig-loop").textContent = s.isStuckInLoop ? "true" : "false";
      document.getElementById("sig-loop").className = "signal-value" + (s.isStuckInLoop ? " warn" : "");
      document.getElementById("sig-directive").textContent = s.hasArchitectDirective ? "true" : "false";
      document.getElementById("sig-attempts").textContent = s.totalAttempts ?? 0;

      // Threshold bar (0-7 range, capped)
      var pct = Math.min((s.consecutiveFailures || 0) / 7, 1) * 100;
      var fill = document.getElementById("threshold-fill");
      fill.style.width = pct + "%";
      fill.className = "threshold-fill";
      if (s.consecutiveFailures >= 6) fill.classList.add("danger");
      else if (s.consecutiveFailures >= 4) fill.classList.add("warning");
    }

    // — History —
    var list = document.getElementById("history-list");
    if (d.history && d.history.length) {
      list.innerHTML = d.history.map(function(h, i) {
        var icon = AGENT_ICONS[h.agent] || "❓";
        var badge = h.success
          ? '<span class="h-badge h-ok">✓</span>'
          : '<span class="h-badge h-fail">✗</span>';
        var errSnippet = h.error ? '<span class="h-error">' + h.error.slice(0, 60) + '</span>' : '';
        return '<div class="h-row">' +
          '<span class="h-num">' + (i + 1) + '</span>' +
          '<span class="h-icon">' + icon + '</span>' +
          '<span class="h-agent">' + h.agent + '</span>' +
          badge +
          errSnippet +
          '</div>';
      }).join("");
      list.scrollTop = list.scrollHeight;
    }

    // — Error terminal —
    var errOut = document.getElementById("error-output");
    if (d.latestLog && d.latestLog.error) {
      errOut.textContent = d.latestLog.error;
    } else if (d.status === "SOLVED") {
      errOut.innerHTML = '<span style="color:var(--accent-green)">✅ Proof verified — no errors</span>';
    }

    lastIteration = d.iteration;
  }

  function poll() {
    fetch(GIST_RAW_URL + "?t=" + Date.now())
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(d) {
        if (d) render(d);
      })
      .catch(function(e) {
        console.warn("[Minutiae] poll error:", e.message);
      });
    setTimeout(poll, POLL_INTERVAL);
  }

  poll();
</script>

<style>
  .minutiae-header {
    padding: 64px 0 0;
  }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .header-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 4px;
  }

  .header-desc {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg-tertiary);
    padding: 6px 14px;
    border-radius: 100px;
    flex-shrink: 0;
    margin-top: 8px;
    border: 1px solid var(--border-color);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .status-badge.live .status-dot {
    background: var(--accent-green);
    box-shadow: 0 0 6px var(--accent-green);
    animation: blink 2s ease-in-out infinite;
  }

  /* ── Status Bar ── */
  .sb-section { padding: 28px 0; }

  .sb {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .sb-item {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 14px 18px;
    transition: background var(--transition-normal), border-color var(--transition-normal);
  }

  .sb-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .sb-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .solved { color: var(--accent-green) !important; }
  .running { color: var(--accent-amber) !important; }
  .exhausted { color: var(--accent-red) !important; }

  /* ── Routing Cascade ── */
  .cascade-section { padding-bottom: 32px; }

  .cascade-grid {
    display: flex;
    align-items: center;
    gap: 0;
    justify-content: center;
  }

  .cascade-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 20px 24px;
    text-align: center;
    min-width: 160px;
    position: relative;
    transition: all 0.3s ease;
  }

  .cascade-card.active {
    border-color: var(--accent);
    background: var(--accent-subtle);
    box-shadow: 0 0 20px var(--accent-subtle);
  }

  .cascade-card.pulse {
    animation: tierPulse 2s ease-in-out infinite;
  }

  @keyframes tierPulse {
    0%, 100% { box-shadow: 0 0 12px var(--accent-subtle); }
    50% { box-shadow: 0 0 28px var(--accent-subtle); }
  }

  .cascade-icon {
    font-size: 1.6rem;
    margin-bottom: 6px;
  }

  .cascade-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .cascade-model {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .cascade-cost {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--accent-green);
    font-weight: 500;
  }

  .cascade-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    padding: 2px 8px;
    color: var(--text-muted);
  }

  .cascade-arrow {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    color: var(--text-muted);
    padding: 0 8px;
    flex-shrink: 0;
  }

  /* ── Signals Panel ── */
  .panels-section { padding-bottom: 32px; }

  .panels-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 20px;
  }

  .signals-panel {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px 20px;
  }

  .signal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .signal-row:last-child { border-bottom: none; }

  .signal-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .signal-value {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .signal-value.warn { color: var(--accent-amber); }

  /* Threshold bar */
  .signal-threshold {
    padding: 10px 0 6px;
  }

  .threshold-bar {
    position: relative;
    height: 6px;
    background: var(--bg-tertiary);
    border-radius: 3px;
    overflow: visible;
  }

  .threshold-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--accent-green);
    transition: width 0.5s ease, background 0.3s ease;
  }

  .threshold-fill.warning { background: var(--accent-amber); }
  .threshold-fill.danger { background: var(--accent-red); }

  .threshold-mark {
    position: absolute;
    top: -4px;
    transform: translateX(-50%);
  }

  .threshold-mark::before {
    content: '';
    display: block;
    width: 2px;
    height: 14px;
    background: var(--text-muted);
    margin: 0 auto;
    opacity: 0.5;
  }

  .threshold-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 2px;
  }

  /* ── History ── */
  .history-list {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    max-height: 330px;
    overflow-y: auto;
  }

  .h-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .h-row:last-child { border-bottom: none; }

  .h-num {
    color: var(--text-muted);
    min-width: 20px;
    text-align: right;
    flex-shrink: 0;
  }

  .h-icon { flex-shrink: 0; }

  .h-agent {
    color: var(--text-primary);
    font-weight: 500;
    min-width: 80px;
  }

  .h-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .h-ok {
    color: var(--accent-green);
    background: var(--accent-green-subtle);
  }

  .h-fail {
    color: var(--accent-red);
    background: rgba(220, 38, 38, 0.06);
  }

  [data-theme="dark"] .h-fail {
    background: rgba(248, 113, 113, 0.08);
  }

  .h-error {
    color: var(--text-muted);
    font-size: 0.65rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 220px;
  }

  /* ── Terminal ── */
  .term-section { padding-bottom: 60px; }

  .terminal-body {
    max-height: 200px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
    color: var(--accent-green);
  }

  .panel-heading {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .empty-msg {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .cascade-grid {
      flex-direction: column;
    }
    .cascade-arrow {
      transform: rotate(90deg);
      padding: 4px 0;
    }
    .panels-grid, .sb {
      grid-template-columns: 1fr;
    }
    .header-row {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
