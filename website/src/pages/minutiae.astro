---
import BaseLayout from '../layouts/BaseLayout.astro';

const GIST_RAW_URL = "https://gist.githubusercontent.com/bneb/66d185688c92067a1878666b311aab1a/raw/perqed_state.json";
---

<BaseLayout title="Minutiae — Perqed Live Feed" activeNav="minutiae">

  <section class="header">
    <div class="container container--wide">
      <div class="header-row">
        <div>
          <p class="eyebrow">Live Feed</p>
          <h1 class="header-title">Minutiae</h1>
          <p class="header-desc">Live telemetry from the proof engine.</p>
        </div>
        <div class="status-badge" id="status-badge">
          <span class="status-dot"></span>
          <span class="status-text" id="status-text">Connecting…</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat cards -->
  <section class="cards-section">
    <div class="container container--wide">
      <div class="cards">
        <div class="card">
          <span class="card-label">Theorem</span>
          <span class="card-value" id="c-theorem">—</span>
        </div>
        <div class="card">
          <span class="card-label">Elapsed</span>
          <span class="card-value" id="c-elapsed">—</span>
        </div>
        <div class="card">
          <span class="card-label">Iteration</span>
          <span class="card-value" id="c-iter">—</span>
        </div>
        <div class="card">
          <span class="card-label">Updated</span>
          <span class="card-value" id="c-updated">—</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Engine pipeline -->
  <section class="pipeline-section">
    <div class="container container--wide">
      <h3 class="panel-label">Engine Pipeline</h3>
      <div class="pipeline">
        <div class="pipe-node" id="pipe-architect">
          <div class="pipe-icon">🏛️</div>
          <div class="pipe-name">ARCHITECT</div>
          <div class="pipe-sub">Gemini · formulates search</div>
        </div>
        <div class="pipe-arrow">→</div>
        <div class="pipe-node" id="pipe-sa">
          <div class="pipe-icon">🌡️</div>
          <div class="pipe-name">SA SEARCH</div>
          <div class="pipe-sub">island model · 8 workers</div>
        </div>
        <div class="pipe-arrow">→</div>
        <div class="pipe-node" id="pipe-z3">
          <div class="pipe-icon">⚡</div>
          <div class="pipe-name">Z3 / LNS</div>
          <div class="pipe-sub">exact finisher</div>
        </div>
        <div class="pipe-arrow">→</div>
        <div class="pipe-node" id="pipe-lean">
          <div class="pipe-icon">✓</div>
          <div class="pipe-name">LEAN 4</div>
          <div class="pipe-sub">kernel verifier</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Current state -->
  <section class="state-section">
    <div class="container container--wide">
      <div class="state-grid">
        <!-- Tactic state -->
        <div>
          <h3 class="panel-label">Current State</h3>
          <div class="state-box">
            <div class="state-row">
              <span class="state-key">activity</span>
              <span class="state-val" id="st-thinking">—</span>
            </div>
            <div class="state-row">
              <span class="state-key">progress</span>
              <span class="state-val mono" id="st-tactic">—</span>
            </div>
          </div>
        </div>

        <!-- Event log -->
        <div>
          <h3 class="panel-label">Event Log</h3>
          <div class="event-list" id="event-list">
            <p class="empty-msg">Waiting for data…</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline define:vars={{ GIST_RAW_URL }}>
  var POLL_MS = 15000;

  var STATUS_CONFIG = {
    proving:  { label: '🔥 SEARCHING', cls: 'searching', pipe: 'pipe-sa' },
    solved:   { label: '✅ SOLVED',    cls: 'solved',    pipe: 'pipe-lean' },
    failed:   { label: '❌ FAILED',    cls: 'failed',    pipe: null },
    idle:     { label: '◌ IDLE',       cls: 'idle',      pipe: null },
  };

  function fmtIter(n) {
    if (!n || n === 0) return '—';
    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';
    if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
    if (n >= 1e3) return (n / 1e3).toFixed(0) + 'K';
    return String(n);
  }

  function fmtTime(iso) {
    if (!iso) return '—';
    try {
      var d = new Date(iso);
      var now = new Date();
      var secs = Math.floor((now - d) / 1000);
      if (secs < 5)  return 'just now';
      if (secs < 60) return secs + 's ago';
      if (secs < 3600) return Math.floor(secs / 60) + 'm ago';
      return d.toLocaleTimeString();
    } catch(e) { return '—'; }
  }

  function activatePipe(pipeId) {
    document.querySelectorAll('.pipe-node').forEach(function(n) {
      n.classList.remove('active', 'pulse');
    });
    if (pipeId) {
      var el = document.getElementById(pipeId);
      if (el) { el.classList.add('active', 'pulse'); }
    }
  }

  function render(d) {
    if (!d) return;

    // Status badge
    var cfg = STATUS_CONFIG[d.status] || { label: d.status || '—', cls: 'idle', pipe: null };
    var badge = document.getElementById('status-badge');
    badge.className = 'status-badge ' + cfg.cls;
    document.getElementById('status-text').textContent = cfg.label;

    // Stat cards
    var theorem = d.theorem || '—';
    // Convert theorem_name like ramsey_R4_6_lower_bound_36 → R(4,6) ≥ 36
    if (theorem.includes('ramsey') && theorem.includes('lower_bound')) {
      var parts = theorem.match(/(\d+)_(\d+).*?(\d+)$/);
      if (parts) theorem = 'R(' + parts[1] + ',' + parts[2] + ') \u2265 ' + parts[3];
    }
    document.getElementById('c-theorem').textContent = theorem;
    document.getElementById('c-elapsed').textContent = d.elapsed || '—';
    document.getElementById('c-iter').textContent = fmtIter(d.iteration);
    document.getElementById('c-updated').textContent = fmtTime(d.timestamp);

    // Pipeline
    activatePipe(cfg.pipe);

    // Current state
    document.getElementById('st-thinking').textContent = d.thinking || '—';
    document.getElementById('st-tactic').textContent = d.tacticState || '—';

    // Events (newest first)
    var list = document.getElementById('event-list');
    if (d.events && d.events.length) {
      var reversed = d.events.slice().reverse();
      list.innerHTML = reversed.map(function(ev) {
        var cls = 'ev-' + (ev.type || 'info');
        var dot = ev.type === 'success' ? '●' : ev.type === 'error' ? '●' : '·';
        return '<div class="ev-row">' +
          '<span class="ev-dot ' + cls + '">' + dot + '</span>' +
          '<span class="ev-time">' + (ev.time || '') + '</span>' +
          '<span class="ev-msg">' + ev.message + '</span>' +
          '</div>';
      }).join('');
    }
  }

  function poll() {
    fetch(GIST_RAW_URL + '?t=' + Date.now())
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(d) { if (d) render(d); })
      .catch(function(e) { console.warn('[minutiae] poll error:', e.message); });
    setTimeout(poll, POLL_MS);
  }

  poll();
</script>

<style>
  .header { padding: 64px 0 0; }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
  }

  .header-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 4px;
  }

  .header-desc { color: var(--text-secondary); font-size: 1rem; }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 6px 14px;
    border-radius: 100px;
    flex-shrink: 0;
    margin-top: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-tertiary);
    color: var(--text-muted);
    transition: all 0.3s ease;
  }

  .status-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
  }

  .status-badge.searching .status-dot {
    background: #f59e0b;
    box-shadow: 0 0 8px #f59e0b;
    animation: blink 1.8s ease-in-out infinite;
  }
  .status-badge.searching { border-color: #f59e0b33; color: #f59e0b; }

  .status-badge.solved .status-dot {
    background: #22c55e;
    box-shadow: 0 0 8px #22c55e;
  }
  .status-badge.solved { border-color: #22c55e33; color: #22c55e; }

  .status-badge.failed .status-dot { background: #ef4444; }
  .status-badge.failed { border-color: #ef444433; color: #ef4444; }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  /* ── Stat cards ── */
  .cards-section { padding: 28px 0 0; }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 14px 18px;
  }

  .card-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .card-value {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  /* ── Pipeline ── */
  .pipeline-section { padding: 32px 0 0; }

  .pipeline {
    display: flex;
    align-items: center;
    gap: 0;
    justify-content: center;
  }

  .pipe-node {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 18px 20px;
    text-align: center;
    min-width: 140px;
    transition: all 0.35s ease;
  }

  .pipe-node.active {
    border-color: var(--accent);
    background: var(--accent-subtle);
  }

  .pipe-node.pulse {
    animation: nodePulse 2s ease-in-out infinite;
  }

  @keyframes nodePulse {
    0%, 100% { box-shadow: 0 0 0 0 transparent; }
    50% { box-shadow: 0 0 18px var(--accent-subtle); }
  }

  .pipe-icon { font-size: 1.4rem; margin-bottom: 4px; }

  .pipe-name {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    margin-bottom: 3px;
  }

  .pipe-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
  }

  .pipe-arrow {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text-muted);
    padding: 0 10px;
    flex-shrink: 0;
  }

  /* ── State + Events ── */
  .state-section { padding: 32px 0 60px; }

  .state-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 20px;
  }

  .state-box {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px 20px;
  }

  .state-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .state-row:last-child { border-bottom: none; }

  .state-key {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .state-val {
    font-size: 0.9rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .state-val.mono { font-family: var(--font-mono); font-size: 0.82rem; }

  .panel-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 12px;
  }

  /* ── Event log ── */
  .event-list {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    max-height: 280px;
    overflow-y: auto;
  }

  .ev-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 5px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .ev-row:last-child { border-bottom: none; }

  .ev-dot {
    font-size: 0.55rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .ev-info  { color: var(--text-muted); }
  .ev-success { color: #22c55e; }
  .ev-error { color: #ef4444; }

  .ev-time {
    color: var(--text-muted);
    min-width: 36px;
    flex-shrink: 0;
  }

  .ev-msg { color: var(--text-secondary); }

  .empty-msg {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .cards { grid-template-columns: repeat(2, 1fr); }
    .pipeline { flex-direction: column; }
    .pipe-arrow { transform: rotate(90deg); padding: 4px 0; }
    .state-grid { grid-template-columns: 1fr; }
    .header-row { flex-direction: column; }
  }
</style>
