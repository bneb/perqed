---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Minutiae — Perqed Live Feed" activeNav="minutiae">

  <section class="minutiae-header">
    <div class="container container--wide">
      <div class="header-row">
        <div>
          <p class="eyebrow">Live Feed</p>
          <h1 class="header-title">Minutiae</h1>
          <p class="header-desc">
            Watch the proof engine reason through mathematics in real time.
          </p>
        </div>
        <div class="status-badge" id="status-badge">
          <span class="status-dot"></span>
          <span class="status-text">Connecting…</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Status Bar -->
  <section class="sb-section">
    <div class="container container--wide">
      <div class="sb">
        <div class="sb-item">
          <span class="sb-label">Theorem</span>
          <span class="sb-value" id="sb-theorem">—</span>
        </div>
        <div class="sb-item">
          <span class="sb-label">Iteration</span>
          <span class="sb-value" id="sb-iteration">—</span>
        </div>
        <div class="sb-item">
          <span class="sb-label">Elapsed</span>
          <span class="sb-value" id="sb-elapsed">—</span>
        </div>
        <div class="sb-item">
          <span class="sb-label">Status</span>
          <span class="sb-value" id="sb-status">—</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Terminals -->
  <section class="term-section">
    <div class="container container--wide">
      <div class="term-grid">
        <div class="terminal">
          <div class="terminal-header">
            <span class="terminal-dot terminal-dot--red"></span>
            <span class="terminal-dot terminal-dot--amber"></span>
            <span class="terminal-dot terminal-dot--green"></span>
            <span class="terminal-title">lean — tactic state</span>
          </div>
          <div class="terminal-body" id="tactic-state">
            <span class="cursor-blink">▊</span>
          </div>
        </div>

        <div class="terminal">
          <div class="terminal-header">
            <span class="terminal-dot terminal-dot--red"></span>
            <span class="terminal-dot terminal-dot--amber"></span>
            <span class="terminal-dot terminal-dot--green"></span>
            <span class="terminal-title">deepseek-r1:8b — reasoning</span>
          </div>
          <div class="terminal-body" id="llm-thinking">
            <span class="cursor-blink">▊</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Panels -->
  <section class="panels-section">
    <div class="container container--wide">
      <div class="panels-grid">
        <div>
          <h3 class="panel-heading">Proposed Tactics</h3>
          <div id="tactics-list" class="tactics-list">
            <p class="empty-msg">Waiting for data…</p>
          </div>
        </div>

        <div>
          <h3 class="panel-heading">Event Log</h3>
          <div id="event-log" class="event-log">
            <p class="empty-msg">Waiting for events…</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  var DEMO = {
    theorem: "nat_add_comm (n m : Nat) : n + m = m + n",
    iteration: 1,
    elapsed: "47s",
    status: "SOLVED",
    tacticState: "n m : Nat\n⊢ n + m = m + n",
    thinking: "Okay, I need to prove that n + m = m + n for natural numbers.\n\nThis is the commutativity of addition. Let me think about what tactics are available in Lean 4 / Mathlib...\n\nOption 1: \"omega\" — this is a decision procedure for linear arithmetic over integers and naturals. It should handle this directly.\n\nOption 2: \"simp [Nat.add_comm]\" — this uses the simplifier with the known commutativity lemma.\n\nOption 3: Manual induction on n, then use succ_add and the inductive hypothesis. More verbose but always works.\n\nI'm most confident in omega since it's a complete decision procedure for this class of problems.",
    tactics: [
      { tactic: "omega", confidence: 0.95, result: "complete" },
      { tactic: "simp [Nat.add_comm]", confidence: 0.82, result: "complete" },
      { tactic: "induction n with | zero => simp | succ n ih => simp [Nat.succ_add, ih]", confidence: 0.70, result: null }
    ],
    events: [
      { time: "00:00", message: "Z3 pre-flight: unsat (no counterexample found)" },
      { time: "00:01", message: "FormalistAgent: sending tactic state to deepseek-r1:8b" },
      { time: "00:32", message: "LLM response received (1,847 think tokens + JSON)" },
      { time: "00:32", message: "Dispatching 3 tactics via Promise.all()" },
      { time: "00:47", message: "✓ Proof complete — omega (confidence: 0.95)" },
      { time: "00:47", message: "Committed to verified_lib/nat_add_comm.lean" }
    ]
  };

  var GIST_ID = "";
  var GIST_URL = GIST_ID ? "https://gist.githubusercontent.com/raw/" + GIST_ID + "/perqed_state.json" : null;

  function render(d) {
    var badge = document.getElementById("status-badge");
    badge.querySelector(".status-text").textContent = GIST_URL ? "Live" : "Demo";
    badge.classList.toggle("live", !!GIST_URL);

    document.getElementById("sb-theorem").textContent = d.theorem || "—";
    document.getElementById("sb-iteration").textContent = d.iteration || "—";
    document.getElementById("sb-elapsed").textContent = d.elapsed || "—";
    var st = document.getElementById("sb-status");
    st.textContent = d.status || "—";
    st.className = "sb-value";
    if (d.status === "SOLVED") st.classList.add("solved");
    else if (d.status === "RUNNING") st.classList.add("running");

    document.getElementById("tactic-state").textContent = d.tacticState || "";
    document.getElementById("llm-thinking").textContent = d.thinking || "";

    var list = document.getElementById("tactics-list");
    if (d.tactics && d.tactics.length) {
      list.innerHTML = d.tactics.map(function(t, i) {
        return '<div class="tactic-row"><span class="tactic-rank">#' + (i+1) + '</span><code class="tactic-code">' + t.tactic + '</code><span class="tactic-conf">' + Math.round(t.confidence * 100) + '%</span>' + (t.result === "complete" ? '<span class="tactic-ok">✓</span>' : '') + '</div>';
      }).join("");
    }

    var log = document.getElementById("event-log");
    if (d.events && d.events.length) {
      log.innerHTML = d.events.map(function(e) {
        return '<div class="event-row"><span class="event-time">' + e.time + '</span><span class="event-msg">' + e.message + '</span></div>';
      }).join("");
    }
  }

  function poll() {
    if (!GIST_URL) { render(DEMO); return; }
    fetch(GIST_URL + "?t=" + Date.now())
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(d) { if (d) render(d); })
      .catch(function() {});
    setTimeout(poll, 10000);
  }

  poll();
</script>

<style>
  .minutiae-header {
    padding: 64px 0 0;
  }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .header-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 4px;
  }

  .header-desc {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg-tertiary);
    padding: 6px 14px;
    border-radius: 100px;
    flex-shrink: 0;
    margin-top: 8px;
    border: 1px solid var(--border-color);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .status-badge.live .status-dot {
    background: var(--accent-green);
    box-shadow: 0 0 6px var(--accent-green);
    animation: blink 2s ease-in-out infinite;
  }

  /* Status Bar */
  .sb-section { padding: 28px 0; }

  .sb {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .sb-item {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 14px 18px;
    transition: background var(--transition-normal), border-color var(--transition-normal);
  }

  .sb-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .sb-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .solved { color: var(--accent-green) !important; }
  .running { color: var(--accent-amber) !important; }

  /* Terminals */
  .term-section { padding-bottom: 24px; }

  .term-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 20px;
  }

  .terminal-body {
    max-height: 320px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
    color: var(--accent-green);
  }

  /* Panels */
  .panels-section { padding-bottom: 60px; }

  .panels-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .panel-heading {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .empty-msg {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Tactics */
  .tactic-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 0.82rem;
  }

  .tactic-rank {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .tactic-code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    flex: 1;
    color: var(--text-primary);
    border: none;
    background: none;
    padding: 0;
  }

  .tactic-conf {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .tactic-ok {
    color: var(--accent-green);
    font-weight: 700;
  }

  /* Events */
  .event-row {
    display: flex;
    gap: 12px;
    padding: 6px 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.5;
    border-bottom: 1px solid var(--border-subtle);
  }

  .event-time {
    color: var(--text-muted);
    flex-shrink: 0;
    min-width: 36px;
  }

  .event-msg {
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .term-grid, .panels-grid, .sb {
      grid-template-columns: 1fr;
    }
    .header-row {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
