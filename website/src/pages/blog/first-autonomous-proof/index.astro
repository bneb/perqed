    <div class="container">
      <div class="prose">
        <header class="article-header">
          <div class="article-meta">
            <time>March 14, 2026</time>
            <span class="sep">·</span>
            <span>10 min read</span>
          </div>
          <h1>Two Autonomous Proofs, Two Paradigms</h1>
        </header>

        <div set:html={blogContent} />
      </div>
    </div>
  </article>

</BaseLayout>

