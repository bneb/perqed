  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script is:inline>
(function() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var grid = isDark ? 'rgba(31,41,55,0.6)' : 'rgba(229,231,235,0.8)';
  var tick = isDark ? '#6b7280' : '#9ca3af';
  var blue = isDark ? '#60a5fa' : '#2563eb';
  var red = isDark ? '#f87171' : '#dc2626';
  var green = isDark ? '#34d399' : '#059669';

  var sx = { type: 'logarithmic', ticks: { color: tick, font: { size: 11 }, callback: function(v){return v;} }, grid: { color: grid } };
  var sy = { ticks: { color: tick, font: { size: 11 } }, grid: { color: grid }, min: 0, max: 0.45 };
  var leg = { labels: { color: tick, font: { size: 12 } } };

  new Chart(document.getElementById('chart-scaling'), {
    type: 'line',
    data: { 
      labels: [50, 100, 200, 500, 1000, 2000, 5000, 10000, 20000, 50000, 100000],
      datasets: [
        { 
          label: 'Selberg Weighting', 
          data: [0.226, 0.219, 0.229, 0.234, 0.228, 0.194, 0.172, 0.144, 0.111, 0.077, 0.060],
          borderColor: blue, backgroundColor: blue, fill: false, tension: 0.1, pointRadius: 4 
        },
        { 
          label: 'Sharp Weighting (μ(n))', 
          data: [0.387, 0.360, 0.311, 0.245, 0.205, 0.158, 0.104, 0.072, 0.052, 0.034, 0.024],
          borderColor: red, backgroundColor: red, fill: false, tension: 0.1, pointRadius: 4 
        },
        { 
          label: 'Ramanujan Weighting', 
          data: [0.297, 0.250, 0.257, 0.193, 0.177, 0.158, 0.109, 0.081, 0.066, 0.045, 0.034],
          borderColor: green, backgroundColor: green, fill: false, tension: 0.1, pointRadius: 4 
        }
      ] 
    },
    options: { 
      responsive:true, maintainAspectRatio:false, plugins:{legend:leg},
      scales: { 
        x: Object.assign({},sx,{title:{display:true,text:'Amplifier Cutoff Length N (Log Scale)',color:tick}}),
        y: Object.assign({},sy,{title:{display:true,text:'max|S(h)| / S(0)',color:tick}}) 
      } 
    }
  });
})();
</script>
