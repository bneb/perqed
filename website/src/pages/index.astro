---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Perqed" activeNav="home">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow animate-in">Autonomous Proof Engine</p>
      <h1 class="hero-title animate-in animate-in-1">
        Automated theorem<br>proving in Lean&nbsp;4.
      </h1>
      <p class="hero-sub animate-in animate-in-2">
        Perqed is an open-source system that reads mathematical literature,
        generates conjectures, and attempts to prove them in Lean&nbsp;4
        using MCTS-guided tactic search. It runs locally on Apple Silicon.
      </p>
      <div class="hero-actions animate-in animate-in-3">
        <a href="https://github.com/bneb/perqed" target="_blank" rel="noopener" class="btn btn-primary">
          View on GitHub
        </a>
        <a href="/minutiae/" class="btn btn-ghost">
          Watch it think →
        </a>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Architecture</p>
      <h2 class="section-heading">The proof loop</h2>
      <p class="section-lede">
        LLMs propose tactics, Lean&nbsp;4 verifies each step, Z3 pre-filters false conjectures.
      </p>

      <div class="steps">
        <div class="step">
          <span class="step-n">01</span>
          <h3 class="step-title">Read the Literature</h3>
          <p class="step-body">
            The Librarian fetches papers from arXiv, chunks abstracts, embeds them via
            <code>nomic-embed-text</code>, and stores vectors in LanceDB for semantic retrieval.
          </p>
          <span class="step-tech">LanceDB · Ollama · RAG</span>
        </div>

        <div class="step">
          <span class="step-n">02</span>
          <h3 class="step-title">Falsify First</h3>
          <p class="step-body">
            Before attempting a proof, Z3 checks for counterexamples in bounded domains.
            False conjectures are typically caught in under 50ms.
          </p>
          <span class="step-tech">Z3 · SMT Solver</span>
        </div>

        <div class="step">
          <span class="step-n">03</span>
          <h3 class="step-title">AND/OR MCTS</h3>
          <p class="step-body">
            Tactics like <code>induction</code> split goals into AND nodes (all must succeed).
            Alternative tactics form OR nodes (any can succeed). The TreeScorer backpropagates
            win probabilities: OR&nbsp;=&nbsp;max, AND&nbsp;=&nbsp;product.
          </p>
          <span class="step-tech">ProofTree · TreeScorer · Value Backpropagation</span>
        </div>

        <div class="step">
          <span class="step-n">04</span>
          <h3 class="step-title">Async Batch Search</h3>
          <p class="step-body">
            Up to 3 nodes expand concurrently via <code>Promise.all()</code>. Tactic
            generation and proof checking run in parallel.
          </p>
          <span class="step-tech">DeepSeek Prover V2 · Promise.all</span>
        </div>

        <div class="step">
          <span class="step-n">05</span>
          <h3 class="step-title">Lean-as-DSL</h3>
          <p class="step-body">
            Lean 4 is the ground truth. The LLM reads tactic state and proposes
            tactics; Lean verifies each step before it is committed.
          </p>
          <span class="step-tech">Lean 4 · Formal Verification</span>
        </div>

        <div class="step">
          <span class="step-n">06</span>
          <h3 class="step-title">Self-Improvement</h3>
          <p class="step-body">
            Solved proofs are parsed into (State, Tactic) pairs
            and saved as deduplicated SFT training data.
          </p>
          <span class="step-tech">DatasetExtractor · sft_dataset.jsonl</span>
        </div>

        <div class="step">
          <span class="step-n">07</span>
          <h3 class="step-title">Auto-Publish</h3>
          <p class="step-body">
            A separate agent translates verified Lean 4 proofs into
            AMS-LaTeX documents with theorem environments and numbered equations.
          </p>
          <span class="step-tech">ScribeAgent · AMS-LaTeX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Model Stack</p>
      <h2 class="section-heading">Runs on your hardware</h2>
      <p class="section-lede">
        Core proving runs locally. Cloud APIs are optional for strategic planning.
      </p>

      <div class="stack">
        <div class="stack-item">
          <h3 class="stack-name">DeepSeek Prover V2:7B Q8</h3>
          <p class="stack-role">Tactician</p>
          <p class="stack-detail">Raw Lean 4 tactic generation. 1-2s per completion on Apple Silicon. ~7 GB VRAM.</p>
        </div>
        <div class="stack-item">
          <h3 class="stack-name">Lean 4.28.0</h3>
          <p class="stack-role">Proof Kernel</p>
          <p class="stack-detail">Formal verification via tactic mode. All proof steps are kernel-checked.</p>
        </div>
        <div class="stack-item">
          <h3 class="stack-name">nomic-embed-text</h3>
          <p class="stack-role">Embedder (RAG)</p>
          <p class="stack-detail">768-dim local embeddings for semantic premise retrieval from the arXiv corpus.</p>
        </div>
        <div class="stack-item">
          <h3 class="stack-name">LanceDB</h3>
          <p class="stack-role">Vector Store</p>
          <p class="stack-detail">Serverless embedded database. Stores arXiv chunks and Mathlib theorems for retrieval.</p>
        </div>
        <div class="stack-item">
          <h3 class="stack-name">Z3</h3>
          <p class="stack-role">SMT Pre-flight</p>
          <p class="stack-detail">Bounded model checking. Filters out false conjectures before proof search begins.</p>
        </div>
        <div class="stack-item">
          <h3 class="stack-name">Gemini 2.5 Flash / 3.1 Pro</h3>
          <p class="stack-role">Architect · Reasoner · Scribe</p>
          <p class="stack-detail">Strategic redirect, proof planning, RAG-augmented directives, and LaTeX paper generation. ~$0.03/proof blended.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container" style="text-align: center;">
      <h2 class="cta-heading">Building in public</h2>
      <p class="cta-body">
        Watch proof attempts in real time or read about progress on the blog.
      </p>
      <div class="cta-actions">
        <a href="/minutiae/" class="btn btn-primary">Live Feed →</a>
        <a href="/blog/" class="btn btn-ghost">Read the Blog</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: 96px 0 72px;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 5.5vw, 3.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 24px;
    color: var(--text-primary);
  }

  .hero-sub {
    font-size: 1.12rem;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Sections */
  .section {
    padding: 80px 0;
    border-top: 1px solid var(--border-color);
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .section-lede {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 480px;
    line-height: 1.7;
  }

  /* Architecture Steps */
  .steps {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 56px;
    margin-top: 48px;
  }

  .step-n {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 10px;
  }

  .step-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .step-body {
    font-size: 0.93rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .step-tech {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  /* Stack */
  .stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px 56px;
    margin-top: 48px;
  }

  .stack-name {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 2px;
    letter-spacing: -0.01em;
  }

  .stack-role {
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: 8px;
    font-weight: 500;
  }

  .stack-detail {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* CTA */
  .cta {
    padding: 80px 0 40px;
    border-top: 1px solid var(--border-color);
  }

  .cta-heading {
    font-family: var(--font-serif);
    font-size: 1.9rem;
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: -0.025em;
  }

  .cta-body {
    color: var(--text-secondary);
    max-width: 440px;
    margin: 0 auto 32px;
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .hero { padding: 56px 0 40px; }
    .section { padding: 48px 0; }
    .steps, .stack { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
