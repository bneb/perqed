# ──────────────────────────────────────────────
# Perqed Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Google Gemini API key (required for ARCHITECT role)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# GitHub Gist Telemetry (optional — enables live dashboard)
# Create a Gist, then generate a PAT with gist scope
GITHUB_GIST_TOKEN=
GITHUB_GIST_ID=
